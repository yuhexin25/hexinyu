---
interface Props {
  title: string;
  year: string;
  description: string;
  tags: string[];
  href?: string;
}

const { title, year, description, tags, href = '#' } = Astro.props;
---

<article class="project-card">
  <div class="project-year">{year}</div>
  <div class="project-body">
    <h3>{title}</h3>
    <p>{description}</p>
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <a class="visit-link" href={href}>Visit site -></a>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    gap: 28px;
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }

  .project-year {
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.35;
  }

  .project-body {
    max-width: 760px;
  }

  h3 {
    margin-bottom: 10px;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 520;
  }

  p {
    color: var(--muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 12px;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    color: #536170;
    font-size: 0.9rem;
  }

  .tag-list li::before {
    content: '#';
    color: var(--accent);
  }

  .visit-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.94rem;
  }

  @media (max-width: 640px) {
    .project-card {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 24px 0;
    }
  }
</style>
