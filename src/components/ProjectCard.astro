---
interface Props {
  title: string;
  year: string;
  description: string;
  researchQuestion: string;
  methods: string;
  data: string;
  status: 'Active' | 'In Progress' | 'Published' | 'Planned';
  tags: string[];
  href?: string;
  linkLabel?: string;
  external?: boolean;
  image?: string;
  imageAlt?: string;
  variant?: 'row' | 'card';
}

const {
  title,
  year,
  description,
  researchQuestion,
  methods,
  data,
  status,
  tags,
  href,
  linkLabel = 'View project',
  external = true,
  image,
  imageAlt = `${title} project preview`,
  variant = 'card',
} = Astro.props;

const imageSrc = image ? `${import.meta.env.BASE_URL}${image.replace(/^\//, '')}` : undefined;
const projectHref = href && !external ? `${import.meta.env.BASE_URL}${href.replace(/^\//, '')}` : href;
---

<article class:list={['project-card', variant === 'card' && 'project-card--card']}>
  {imageSrc && (
    <div class="project-preview">
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    </div>
  )}
  <div class="project-meta-row"><span class="project-year">{year}</span><span class:list={['project-status', `status-${status.toLowerCase().replace(' ', '-')}`]}>{status}</span></div>
  <div class="project-body">
    <div class="project-title-row">
      <span class="project-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M3 12.2 21 4l-5.8 16-3.6-6.6L3 12.2Z" />
          <path d="m11.6 13.4 4.8-5.1" />
        </svg>
      </span>
      <h3>{title}</h3>
    </div>
    <p>{description}</p>
    <dl class="research-meta">
      <div><dt>Research Question</dt><dd>{researchQuestion}</dd></div>
      <div><dt>Methods</dt><dd>{methods}</dd></div>
      <div><dt>Data</dt><dd>{data}</dd></div>
    </dl>
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="project-actions">
      <span>Links</span>
      {projectHref && <a class="project-button project-button-primary" href={projectHref} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>{linkLabel}</a>}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    width: 100%;
    min-width: 0;
    gap: 18px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.07), transparent 42%),
      #fff;
    box-shadow: 0 12px 30px rgba(63, 47, 31, 0.06);
    padding: 2rem;
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .project-card:hover {
    border-color: rgba(245, 158, 11, 0.42);
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .project-preview {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(245, 158, 11, 0.22);
    border-radius: 18px;
    background: #1e293b;
  }

  .project-preview::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 44%);
    content: '';
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .project-card:hover .project-preview::after {
    opacity: 1;
  }

  .project-preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .project-card:hover .project-preview img {
    transform: scale(1.035);
  }

  .project-meta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
  }

  .project-year,
  .project-status {
    display: inline-flex;
    width: fit-content;
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 4px 10px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .project-status {
    border-color: rgba(82, 124, 168, 0.24);
    background: #eef4fa;
    color: #385b7d;
  }

  .status-active {
    border-color: rgba(42, 130, 96, 0.28);
    background: #eaf7f1;
    color: #256e55;
  }

  .status-in-progress {
    border-color: rgba(181, 101, 118, 0.28);
    background: #fbf0f3;
    color: #8c4f5d;
  }

  .project-body {
    display: grid;
    min-width: 0;
    align-content: start;
  }

  .project-title-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
    min-width: 0;
  }

  .project-icon {
    display: inline-grid;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 12px;
    background: var(--gold-soft);
    color: var(--gold-dark);
  }

  .project-icon svg {
    width: 18px;
    height: 18px;
  }

  .project-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  h3 {
    margin-bottom: 0;
    min-width: 0;
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
    font-weight: 720;
    letter-spacing: -0.02em;
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
  }

  p {
    color: var(--muted);
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
  }

  .research-meta {
    display: grid;
    gap: 9px;
    margin: 18px 0 0;
  }

  .research-meta div {
    display: grid;
    gap: 2px;
    border-left: 2px solid rgba(245, 158, 11, 0.34);
    padding-left: 10px;
  }

  .research-meta dt {
    color: var(--gold-dark);
    font-size: 0.67rem;
    font-weight: 820;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .research-meta dd {
    margin: 0;
    color: #526071;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 12px;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    color: #6b5f4e;
    font-size: 0.9rem;
  }

  .tag-list li::before {
    content: '#';
    color: var(--gold);
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .project-actions > span {
    width: 100%;
    color: var(--gold-dark);
    font-size: 0.67rem;
    font-weight: 820;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .project-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: #fff;
    color: var(--text);
    padding: 0 14px;
    font-size: 0.94rem;
    font-weight: 760;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .project-button:hover {
    border-color: var(--gold);
    background: var(--gold-soft);
    color: var(--gold-dark);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .project-button-primary {
    border-color: var(--gold);
    background: var(--gold);
    color: #1e293b;
    box-shadow: 0 10px 22px rgba(245, 158, 11, 0.2);
  }

  .project-button-primary:hover {
    border-color: var(--gold-dark);
    background: var(--gold-dark);
    color: #fff;
  }

  .project-card--card {
    min-height: 690px;
  }

  .project-card--card:hover {
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.1), transparent 46%),
      var(--paper);
  }

  @media (max-width: 640px) {
    .project-card {
      padding: 1.5rem;
    }

    .project-card--card {
      min-height: auto;
    }
  }
</style>
