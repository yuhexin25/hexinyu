---
interface Props {
  title: string;
  year: string;
  description: string;
  researchQuestion?: string;
  methods?: string;
  data?: string;
  status: 'Active' | 'In Progress' | 'Published' | 'Planned';
  tags: string[];
  href?: string;
  linkLabel?: string;
  external?: boolean;
  image?: string;
  imageAlt?: string;
  variant?: 'row' | 'card';
}

const {
  title,
  year,
  description,
  status,
  tags,
  href,
  external = true,
  image,
  imageAlt = `${title} project preview`,
  variant = 'card',
} = Astro.props;

const imageSrc = image ? `${import.meta.env.BASE_URL}${image.replace(/^\//, '')}` : undefined;
const projectHref = href && !external ? `${import.meta.env.BASE_URL}${href.replace(/^\//, '')}` : href;
const visibleTags = tags.slice(0, 3);
---

<article class:list={['project-card', variant === 'card' && 'project-card--card']}>
  {projectHref && (
    <a class="project-card-link" href={projectHref} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined} aria-label={`View ${title}`}></a>
  )}
  {imageSrc && (
    <div class="project-preview">
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    </div>
  )}
  <div class="project-body">
    <div class="project-meta-row"><span class="project-year">{year}</span><span class:list={['project-status', `status-${status.toLowerCase().replace(' ', '-')}`]}>{status}</span></div>
    <div class="project-title-row">
      <h3>{title}</h3>
    </div>
    <p>{description}</p>
    <ul class="tag-list" aria-label={`${title} tags`}>
      {visibleTags.map((tag) => <li>{tag}</li>)}
    </ul>
  </div>
</article>

<style>
  .project-card {
    position: relative;
    display: grid;
    width: 100%;
    min-width: 0;
    gap: 14px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(63, 47, 31, 0.045);
    padding: 14px;
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .project-card:hover {
    border-color: rgba(245, 158, 11, 0.42);
    box-shadow: 0 16px 32px rgba(63, 47, 31, 0.075);
    transform: translateY(-2px);
  }

  .project-card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
  }

  .project-preview {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(245, 158, 11, 0.22);
    border-radius: 12px;
    background: #1e293b;
  }

  .project-preview::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 44%);
    content: '';
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .project-card:hover .project-preview::after {
    opacity: 1;
  }

  .project-preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .project-card:hover .project-preview img {
    transform: scale(1.035);
  }

  .project-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 10px;
  }

  .project-year,
  .project-status {
    display: inline-flex;
    width: fit-content;
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 4px 10px;
    font-size: 0.74rem;
    font-weight: 800;
  }

  .project-status {
    border-color: rgba(82, 124, 168, 0.24);
    background: #eef4fa;
    color: #385b7d;
  }

  .status-active {
    border-color: rgba(42, 130, 96, 0.28);
    background: #eaf7f1;
    color: #256e55;
  }

  .status-in-progress {
    border-color: rgba(181, 101, 118, 0.28);
    background: #fbf0f3;
    color: #8c4f5d;
  }

  .project-body {
    display: grid;
    min-width: 0;
    align-content: start;
  }

  .project-title-row {
    margin-bottom: 8px;
    min-width: 0;
  }

  h3 {
    margin-bottom: 0;
    min-width: 0;
    font-size: clamp(1.1rem, 1.6vw, 1.28rem);
    font-weight: 720;
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  p {
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.5;
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    border: 1px solid rgba(214, 211, 209, 0.9);
    border-radius: 999px;
    background: #fffaf2;
    color: #6b5f4e;
    padding: 3px 8px;
    font-size: 0.72rem;
    font-weight: 650;
  }

  .project-card--card {
    min-height: 0;
  }

  .project-card--card:hover {
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.1), transparent 46%),
      var(--paper);
  }

  @media (max-width: 640px) {
    .project-card {
      border-radius: 16px;
    }

    .project-card--card {
      min-height: auto;
    }
  }
</style>
