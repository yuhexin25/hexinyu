---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';

const base = import.meta.env.BASE_URL;
// Project thumbnails use live-page screenshots as temporary placeholders.
// Replace these image paths later with custom cropped screenshots from each project output.
const featuredProjects = [
  {
    number: '01',
    title: 'U.S. Airline Hub Atlas',
    type: 'Interactive Map',
    description: 'Interactive visualization of U.S. airline hub structures and connectivity patterns.',
    researchQuestion: 'How do hub-and-spoke structures shape airline connectivity?',
    methods: 'Network analysis, MapLibre, D3',
    data: 'FAA, BTS, airline route data',
    tags: ['MapLibre', 'D3', 'FAA/BTS'],
    href: 'https://yuhexin25.github.io/us-airline-hub-atlas/',
    image: `${base}project-previews/hub-atlas-real.png`,
    imageAlt: 'Screenshot of the U.S. Airline Hub Atlas showing routes, hub airports, and network metrics.',
    external: true,
  },
  {
    number: '02',
    title: 'Live Flight Delay Analysis',
    type: 'Live Dashboard',
    description: 'Real-time aviation delay monitoring and route risk assessment using FAA and aviation data.',
    researchQuestion: 'How do real-time disruptions affect airport and route reliability?',
    methods: 'API integration, dashboard design, delay risk scoring',
    data: 'FAA, FlightAware and public aviation sources',
    tags: ['Dashboard', 'FAA Data', 'Risk Scoring'],
    href: 'https://yuhexin25.github.io/livedelayanalysis/',
    image: `${base}project-previews/live-delay-page.png`,
    imageAlt: 'Screenshot of the Live Flight Delay Analysis project page showing the Hub Resilience Monitor.',
    external: true,
  },
  {
    number: '03',
    title: 'World Cup Air Travel Network',
    type: 'Research Article',
    description: 'Analysis of fan mobility and airline network responses during FIFA World Cup 2026.',
    researchQuestion: 'How do major sporting events reshape international air mobility?',
    methods: 'GIS, network visualization, comparative case analysis',
    data: 'FIFA host cities, airline networks, public aviation sources',
    tags: ['GIS', 'Network Analysis', 'World Cup'],
    href: `${base}blog/hubs-alliances-world-cup-mobility/`,
    image: `${base}project-previews/world-cup-article-page.png`,
    imageAlt: 'Screenshot of the World Cup aviation blog article page showing the hubs and alliances analysis.',
    external: false,
  },
];
const readingNotes = (await getCollection('reading-notes')).sort(
  (a, b) => `${a.data.source.name} ${a.data.title}`.localeCompare(`${b.data.source.name} ${b.data.title}`),
);
const featuredLibraryNote = readingNotes[0];
const featuredLibraryHref = featuredLibraryNote
  ? `${base}reading-notes/${featuredLibraryNote.data.source.slug}/${featuredLibraryNote.data.noteSlug}`
  : `${base}reading-notes`;
const featuredBlogArticle = {
  title: 'World Cup 2026 and the U.S. Aviation System',
  description:
    'Demand waves, summer thunderstorms, and field observations from Houston.',
  href: `${base}blog/world-cup-us-aviation-system/`,
  image: `${base}research/houston-match-attendance.jpg`,
  meta: 'June 20, 2026 / 7 min read',
};
const currentProjects = [
  { title: 'Live Flight Delay Analysis', status: 'Active development', tone: 'active' },
  { title: 'World Cup Air Travel Network', status: 'Writing and visualization', tone: 'progress' },
  { title: 'Hub vs Regional Airport Study', status: 'Planned analysis', tone: 'planned' },
];
---

<Layout
  title="Aviation Analytics Portfolio"
  description="Hexin Yu is a Virginia Tech Computational Modeling & Data Analytics student interested in aviation analytics, transportation systems, data visualization, and network analysis."
>
  <section class="hero-section" aria-labelledby="home-title">
    <div class="container priority-grid">
      <div class="hero-copy">
        <h1 id="home-title">Hexin Yu</h1>
        <p class="hero-subtitle">Computational Modeling & Data Analytics Student<br />Virginia Tech</p>
        <p class="gpa-line">GPA: 4.0/4.0</p>
        <p class="lead">
          Data-driven work on aviation networks and transportation systems.
        </p>
        <div class="button-row">
          <a class="button" href={`${base}projects`}>View Projects</a>
          <a class="button secondary" href={`${base}Hexin-Yu-CV.pdf`} target="_blank" rel="noopener noreferrer">Download CV</a>
        </div>
      </div>
      <section class="featured-projects" aria-labelledby="featured-projects-heading">
        <div class="featured-projects-heading">
          <h2 id="featured-projects-heading">Selected Work</h2>
          <a href={`${base}projects`}>All projects <span aria-hidden="true">→</span></a>
        </div>
        <div class="featured-project-list">
          {featuredProjects.map((project) => (
            <article class="priority-project-card">
              <img src={project.image} alt={project.imageAlt} />
              <div class="priority-project-copy">
                <div class="project-eyebrow"><span>{project.number}</span><b>{project.type}</b></div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <ul class="priority-tag-list" aria-label={`${project.title} methods and data`}>
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </div>
              <a
                class="view-project"
                href={project.href}
                target={project.external ? '_blank' : undefined}
                rel={project.external ? 'noopener noreferrer' : undefined}
              >View project <span aria-hidden="true">↗</span></a>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <div class="page-shell home-shell">
    <section class="section current-projects-section" aria-labelledby="current-projects-heading">
      <div class="container current-projects-layout">
        <div>
          <p class="page-kicker">In Progress</p>
          <h2 id="current-projects-heading">Current Projects</h2>
        </div>
        <div class="current-project-list">
          {currentProjects.map((project) => (
            <article>
              <span class:list={['current-status', `current-${project.tone}`]} aria-hidden="true"></span>
              <div><h3>{project.title}</h3><p>{project.status}</p></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section research-interests-section" aria-labelledby="research-interests-heading">
      <div class="container research-interests-card">
        <div>
          <p class="page-kicker">Academic Focus</p>
          <h2 id="research-interests-heading">Research Interests</h2>
          <p>I study aviation systems through data, geography, and network thinking.</p>
        </div>
        <ul class="research-interest-list">
          <li>Airline Networks</li>
          <li>Aviation Reliability</li>
          <li>GIS</li>
          <li>Data Visualization</li>
        </ul>
      </div>
    </section>

    <section class="section featured-research-section" aria-labelledby="featured-research-heading">
      <div class="container section-heading">
        <h2 id="featured-research-heading">Latest Writing</h2>
        <a href={`${base}blog/`}>All posts -&gt;</a>
      </div>
      <a class="featured-research-card container" href={featuredBlogArticle.href}>
        <div class="featured-research-image">
          <img
            src={featuredBlogArticle.image}
            alt="Germany versus Curaçao scoreboard in Houston showing attendance of 68,021"
            loading="lazy"
          />
        </div>
        <div class="featured-research-copy">
          <p class="featured-research-meta">{featuredBlogArticle.meta}</p>
          <h3>{featuredBlogArticle.title}</h3>
          <p>{featuredBlogArticle.description}</p>
          <span>Read the article -&gt;</span>
        </div>
      </a>
    </section>

    {featuredLibraryNote && (
      <section class="section research-notes-section" aria-labelledby="research-notes-heading">
        <div class="container reading-strip">
          <div>
            <p class="page-kicker" id="research-notes-heading">Research Notes</p>
            <h2>
              <a href={featuredLibraryHref}>{featuredLibraryNote.data.title}</a>
            </h2>
            <p>{featuredLibraryNote.data.description}</p>
          </div>
          <div class="reading-meta">
            <span>{featuredLibraryNote.data.source.name}</span>
            <a class="text-link" href={`${base}reading-notes`}>Open library -></a>
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: #fffdf8;
    padding: 56px 0 58px;
  }

  .priority-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(42px, 6vw, 82px);
    align-items: center;
  }

  .hero-copy {
    max-width: 580px;
  }

  .hero-copy .page-kicker {
    color: var(--gold-dark);
  }

  .hero-copy h1 {
    margin-top: 4px;
    color: var(--text);
    font-size: clamp(3rem, 5.2vw, 4.8rem);
  }

  .hero-copy .lead {
    max-width: 440px;
    margin-top: 18px;
    color: #475569;
    font-size: 1rem;
    line-height: 1.6;
  }

  .hero-subtitle {
    margin-top: 8px;
    color: var(--accent-dark);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    font-weight: 760;
    line-height: 1.45;
  }

  .gpa-line {
    width: fit-content;
    margin-top: 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    color: #475569;
    padding: 5px 11px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .hero-copy .button-row {
    margin-top: 24px;
  }

  .hero-copy .button {
    min-height: 42px;
    border-color: var(--border-strong);
    background: #fff;
    color: var(--text);
    padding-inline: 18px;
    font-size: 0.92rem;
    font-weight: 680;
  }

  .hero-copy .button:first-child {
    border-color: #cbd5e1;
    background: #1e293b;
    color: #fff;
  }

  .hero-copy .button:hover,
  .hero-copy .button.secondary:hover {
    border-color: #94a3b8;
    background: #f8fafc;
    color: var(--text);
  }

  .featured-projects {
    min-width: 0;
    border-left: 1px solid var(--border);
    padding-left: clamp(28px, 4vw, 50px);
  }

  .featured-projects-heading {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: end;
    margin-bottom: 14px;
  }

  .featured-projects-heading h2 {
    font-size: clamp(1.55rem, 2.4vw, 2.1rem);
  }

  .featured-projects-heading > a {
    flex: 0 0 auto;
    margin-bottom: 5px;
    color: #475569;
    font-size: 0.86rem;
    font-weight: 760;
  }

  .featured-project-list {
    display: grid;
    gap: 12px;
  }

  .priority-project-card {
    display: grid;
    grid-template-columns: 124px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    overflow: hidden;
    min-height: 134px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: #fff;
    color: var(--text);
    padding: 10px 14px 10px 10px;
    transition: border-color 180ms ease;
  }

  .priority-project-card:hover {
    border-color: var(--border-strong);
    color: var(--text);
    text-decoration: none;
  }

  .priority-project-card img {
    width: 124px;
    height: 112px;
    border-radius: 12px;
    object-fit: cover;
  }

  .priority-project-copy {
    min-width: 0;
  }

  .project-eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 5px 9px;
    align-items: center;
  }

  .project-eyebrow span {
    color: #64748b;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 800;
  }

  .project-eyebrow b {
    color: #64748b;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .priority-project-card h3 {
    margin-top: 3px;
    font-size: clamp(1.02rem, 1.5vw, 1.22rem);
  }

  .priority-project-copy > p {
    max-width: 560px;
    margin-top: 5px;
    color: #5f6b7a;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .priority-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 10px 0 0;
    padding: 0;
    list-style: none;
  }

  .priority-tag-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fafafa;
    color: #64748b;
    padding: 3px 8px;
    font-size: 0.68rem;
    font-weight: 650;
  }

  .priority-tag-list + * {
    margin: 0;
  }

  .view-project {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    min-height: 34px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: #fff;
    color: #334155;
    padding: 7px 10px;
    font-size: 0.73rem;
    font-weight: 800;
  }

  .view-project:hover {
    border-color: #94a3b8;
    color: var(--text);
    text-decoration: none;
  }

  .home-shell {
    padding-top: 0;
  }

  .current-projects-section {
    background: #fff;
    padding-block: 32px;
  }

  .current-projects-layout {
    display: grid;
    grid-template-columns: minmax(180px, 0.3fr) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 52px);
    align-items: start;
  }

  .current-projects-layout h2 {
    margin-top: 3px;
    font-size: clamp(1.45rem, 2.6vw, 2.2rem);
  }

  .current-project-list {
    display: grid;
    gap: 0;
  }

  .current-project-list article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: baseline;
    border-top: 1px solid var(--border);
    padding: 12px 0;
  }

  .current-project-list article:last-child {
    border-bottom: 1px solid var(--border);
  }

  .current-project-list h3 {
    font-size: 0.93rem;
    line-height: 1.3;
  }

  .current-project-list p {
    margin-top: 4px;
    color: #6b7280;
    font-size: 0.72rem;
  }

  .current-status {
    width: 6px;
    height: 6px;
    margin-top: 0;
    border-radius: 50%;
    background: #7394b8;
  }

  .current-active {
    background: #2a8260;
  }

  .current-progress {
    background: var(--gold);
  }

  .featured-research-section {
    background: #fff;
    padding-block: 36px;
  }

  .featured-research-card {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: #fff;
    color: var(--text);
    padding: 0;
  }

  .featured-research-card:hover {
    color: var(--text);
    text-decoration: none;
    border-color: var(--border-strong);
  }

  .featured-research-image {
    min-height: 150px;
  }

  .featured-research-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-research-copy {
    display: grid;
    align-content: center;
    padding: 22px;
  }

  .featured-research-meta {
    color: var(--gold-dark);
    font-size: 0.78rem;
    font-weight: 780;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .featured-research-copy h3 {
    max-width: 660px;
    margin-top: 8px;
    color: var(--text);
    font-size: clamp(1.15rem, 2vw, 1.45rem);
  }

  .featured-research-copy > p:not(.featured-research-meta) {
    max-width: 620px;
    margin-top: 10px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .featured-research-copy > span {
    margin-top: 14px;
    color: #475569;
    font-weight: 750;
  }

  .reading-strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--paper);
    padding: 20px;
  }

  .research-notes-section {
    padding-block: 30px 64px;
  }

  .research-interests-section {
    background: #fff;
    padding-block: 32px;
  }

  .research-interests-card {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(24px, 4vw, 52px);
    align-items: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-block: 26px;
  }

  .research-interests-card h2 {
    max-width: 470px;
    margin-top: 4px;
    font-size: clamp(1.35rem, 2.4vw, 2rem);
  }

  .research-interests-card > div > p:last-child {
    max-width: 410px;
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .research-interest-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .research-interest-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    color: #475569;
    padding: 5px 10px;
    font-size: 0.84rem;
    font-weight: 650;
  }

  .research-interest-list li::before {
    content: none;
  }

  .reading-strip h2 a {
    color: var(--text);
  }

  .reading-strip h2 a:hover {
    color: var(--gold-dark);
    text-decoration: none;
  }

  .reading-strip p {
    max-width: 700px;
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .reading-meta {
    display: grid;
    justify-items: end;
    gap: 10px;
  }

  .reading-meta span {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    color: #64748b;
    padding: 6px 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  @media (max-width: 1020px) {
    .priority-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hero-copy {
      max-width: 680px;
    }

    .featured-projects {
      border-top: 1px solid var(--border);
      border-left: 0;
      padding-top: 28px;
      padding-left: 0;
    }

    .current-projects-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 700px) {
    .current-project-list {
      grid-template-columns: 1fr;
    }
    .research-interests-card {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .research-interest-list {
      gap: 8px;
    }

    .reading-strip {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .featured-research-card {
      grid-template-columns: 1fr;
    }

    .featured-research-image {
      min-height: 190px;
      max-height: 280px;
    }

    .reading-meta {
      justify-items: start;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding: 38px 0 42px;
    }

    .hero-copy h1 {
      font-size: clamp(2.65rem, 14vw, 4rem);
    }

    .featured-projects-heading {
      align-items: start;
      display: grid;
      gap: 8px;
    }

    .priority-project-card {
      grid-template-columns: 1fr;
      gap: 12px;
      min-height: 0;
      padding: 12px;
    }

    .priority-project-card img {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
      grid-row: auto;
    }

    .priority-tag-list {
      gap: 5px;
    }

    .view-project {
      grid-column: auto;
      width: fit-content;
      min-height: 40px;
      padding: 7px 12px;
    }
  }

  @media (max-width: 430px) {
    .hero-section {
      padding: 32px 0 36px;
    }

    .hero-copy .button {
      width: 100%;
    }

    .current-projects-layout,
    .research-interests-card {
      gap: 16px;
    }

    .featured-research-copy {
      padding: 18px;
    }

    .reading-strip {
      padding: 18px;
    }
  }
</style>
