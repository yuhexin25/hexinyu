---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { libraryCategories } from '../../data/researchLibrary';

const notes = await getCollection('reading-notes');
const sourceCounts = notes.reduce<Record<string, number>>((counts, note) => {
  counts[note.data.source.slug] = (counts[note.data.source.slug] || 0) + 1;
  return counts;
}, {});

const sourceHref = (slug: string) => `${import.meta.env.BASE_URL}reading-notes/${slug}`;
const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const noteCountLabel = (count: number) => `${count} ${count === 1 ? 'note' : 'notes'}`;
---

<Layout
  title="Research Library"
  description="A source-based aviation research library by Hexin Yu, organized by industry reports, news analysis, and academic literature."
>
  <div class="library-page">
    <header class="container library-intro">
      <p class="page-kicker">Reading Notes</p>
      <h1>Research Library</h1>
      <p class="lead">
        A source-based knowledge base for aviation analytics, transportation systems, airline networks,
        and flight operations. Notes are organized by source and topic rather than by week.
      </p>
    </header>

    <div class="container library-grid">
      {libraryCategories.map((category) => (
        <section class="category-panel" aria-labelledby={`${slugify(category.name)}-heading`}>
          <div class="category-heading">
            <p class="page-kicker">Category</p>
            <h2 id={`${slugify(category.name)}-heading`}>{category.name}</h2>
            <p>{category.description}</p>
          </div>
          <div class="source-grid">
            {category.sources.map((source) => (
              <a class="source-card" href={sourceHref(source.slug)}>
                <span class="source-name">{source.name}</span>
                <span>{noteCountLabel(sourceCounts[source.slug] || 0)}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
  .library-page {
    padding: clamp(48px, 7vw, 72px) 0 clamp(68px, 8vw, 92px);
  }

  .library-intro {
    max-width: 920px;
    margin-bottom: 44px;
  }

  .library-grid {
    display: grid;
    gap: 26px;
  }

  .category-panel {
    display: grid;
    grid-template-columns: minmax(min(100%, 220px), 0.38fr) minmax(0, 1fr);
    gap: clamp(20px, 4vw, 28px);
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(245, 158, 11, 0.09), rgba(255, 255, 255, 0) 34%),
      var(--paper);
    box-shadow: 0 14px 32px rgba(63, 47, 31, 0.055);
    padding: clamp(20px, 4vw, 28px);
  }

  .category-heading p:not(.page-kicker) {
    margin-top: 12px;
    color: var(--muted);
  }

  .source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 210px), 1fr));
    gap: 14px;
  }

  .source-card {
    display: grid;
    min-height: 108px;
    align-content: space-between;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
    color: var(--text);
    padding: 18px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .source-card:hover {
    border-color: rgba(245, 158, 11, 0.52);
    box-shadow: 0 16px 34px rgba(63, 47, 31, 0.08);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .source-name {
    color: var(--text);
    font-size: 1.12rem;
    font-weight: 760;
  }

  .source-card span:last-child {
    color: var(--gold-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  @media (max-width: 820px) {
    .category-panel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 430px) {
    .category-panel {
      border-radius: 18px;
    }

    .source-card {
      min-height: 96px;
      border-radius: 16px;
      padding: 16px;
    }
  }
</style>
