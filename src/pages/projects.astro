---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projectsByYear } from '../data/projects';

const years = Object.keys(projectsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout
  title="Projects"
  description="A curated archive of Hexin Yu's aviation analytics, flight delay, airline network, and transportation data visualization projects."
>
  <div class="projects-page">
    <header class="projects-container page-intro projects-intro">
      <p class="page-kicker">Projects</p>
      <h1>Curated project archive</h1>
      <p class="lead">
        Each project is a working answer to one question: how can data help us understand aviation networks,
        flight disruptions, and transportation systems?
      </p>
    </header>

    <div class="projects-container year-groups">
      {years.map((year) => (
        <section class="year-group" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`}>{year}</h2>
          <div class="projects-grid">
            {projectsByYear[year].map((project) => <ProjectCard {...project} variant="card" />)}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
  .projects-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4rem) clamp(1rem, 4vw, 1.5rem);
  }

  .projects-container {
    width: 100%;
  }

  .projects-intro {
    max-width: 900px;
  }

  .year-groups {
    display: grid;
    gap: 3rem;
  }

  .year-group {
    display: grid;
    gap: 1.25rem;
  }

  .year-group h2 {
    color: var(--gold-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1.05rem;
    font-weight: 760;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  @media (max-width: 720px) {
    .projects-page {
      padding: 3rem 1rem;
    }

  }
</style>
