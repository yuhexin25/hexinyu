---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const projectList = projects.slice().sort((a, b) => Number(b.year) - Number(a.year) || a.title.localeCompare(b.title));
---

<Layout
  title="Projects"
  description="A curated archive of Hexin Yu's aviation analytics, flight delay, airline network, and transportation data visualization projects."
>
  <div class="projects-page">
    <header class="projects-container page-intro projects-intro">
      <p class="page-kicker">Projects</p>
      <h1>Projects</h1>
      <p class="lead">
        Interactive tools and data projects for aviation networks, flight disruptions, and transportation systems.
      </p>
    </header>

    <div class="projects-container projects-grid">
      {projectList.map((project) => <ProjectCard {...project} variant="card" />)}
    </div>
  </div>
</Layout>

<style>
  .projects-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4rem) clamp(1rem, 4vw, 1.5rem);
  }

  .projects-container {
    width: 100%;
  }

  .projects-intro {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 18px;
  }

  @media (max-width: 720px) {
    .projects-page {
      padding: 3rem 1rem;
    }

  }
</style>
